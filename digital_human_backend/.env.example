# ============================================
# 鏁板瓧浜哄悗绔郴缁熺幆澧冨彉閲忛厤缃ā鏉?# Digital Human Backend Environment Variables
# ============================================
# 
# 浣跨敤鏂规硶锛?# 1. 澶嶅埗姝ゆ枃浠朵负 .env: cp .env.example .env
# 2. 鏍规嵁瀹為檯鎯呭喌淇敼閰嶇疆鍊?# 3. 涓嶈灏?.env 鏂囦欢鎻愪氦鍒扮増鏈帶鍒剁郴缁?#

# ============================================
# 鏈嶅姟閰嶇疆
# ============================================
HOST=0.0.0.0
PORT=8173
DEBUG=False

# ============================================
# 鏁版嵁搴撻厤缃紙鍙€夛紝鏍规嵁瀹為檯闇€姹傚惎鐢級
# ============================================
DATABASE_URL=postgresql://user:password@localhost/digital_human
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://localhost:27017

# ============================================
# Neo4j鍥炬暟鎹簱閰嶇疆
# ============================================
# If using project Docker (data/Neo4j): port 7687, password mem0test123
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jneo4j

# ============================================
# ChromaDB鍚戦噺鏁版嵁搴撻厤缃?# ============================================
CHROMADB_PERSIST_DIR=./data/chromadb

# ============================================
# AI模型配置
# ============================================
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=

# 学校私有大模型（OpenAI 兼容）。设置 LLM_BASE_URL 后 /api/chat 走此路线，不再使用 Ollama
# 完整对话地址示例：https://172.16.59.220/svc/kaDDxL1y-3/v1/chat/completions
LLM_BASE_URL=https://172.16.59.220/svc/kaDDxL1y-3/v1
LLM_API_KEY=lib-llm-2026-secret-key
LLM_DEFAULT_MODEL=qwen2.5-7b-lora-library
# 内网自签证书须关闭 SSL 校验
LLM_VERIFY_SSL=false
# 对方服务输入+输出共 1024 token，建议 max_tokens 留足 prompt 空间
LLM_MAX_TOKENS=512
# 单次 user 消息字符上限、发送给模型的总输入上限、保留的历史轮数
LLM_MAX_MESSAGE_CHARS=800
LLM_MAX_INPUT_CHARS=1800
LLM_MAX_HISTORY_TURNS=3

# 本地 Ollama（未设置 LLM_BASE_URL 时使用）
OLLAMA_BASE_URL=http://localhost:11434

# 不绑定本地知识库（纯转发学校大模型时可留空）
DEFAULT_CHAT_KB_ID=
# 默认对话模型（必须是你本机 `GET /api/tags` 能看到的 name）
# 示例：gemma3:1b / qwen3:latest / EntropyYue/chatglm3:latest
OLLAMA_DEFAULT_MODEL=gemma3:1b

# Unity 下拉框会传 model_key=Chatglm 或 Qwen，这里配置它们映射到的真实 Ollama 模型名
OLLAMA_MODEL_CHATGLM=EntropyYue/chatglm3:latest
OLLAMA_MODEL_QWEN=qwen3:latest

# ============================================
# 妯″瀷鍜屾暟鎹矾寰勯厤缃?# ============================================
MODELS_DIR=./models
DATA_DIR=./data

# ============================================
# CORS璺ㄥ煙閰嶇疆
# ============================================
CORS_ORIGINS=*

# ============================================
# 鏃ュ織閰嶇疆
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
