# 数字人减配后端环境变量示例
# cp .env.example .env  后按需修改（勿提交 .env）

HOST=0.0.0.0
PORT=8173
DEBUG=False

# 学校大模型（OpenAI 兼容）— 后端只负责转发，不托管模型
# 完整对话地址示例：https://172.16.59.220/svc/kaDDxL1y-3/v1/chat/completions
LLM_BASE_URL=https://172.16.59.220/svc/kaDDxL1y-3/v1
LLM_API_KEY=your-school-api-key
LLM_DEFAULT_MODEL=qwen2.5-7b-lora-library
LLM_VERIFY_SSL=false
LLM_MAX_TOKENS=512
LLM_MAX_MESSAGE_CHARS=800
LLM_MAX_INPUT_CHARS=1800
LLM_MAX_HISTORY_TURNS=3

DATA_DIR=./data
CORS_ORIGINS=*
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
