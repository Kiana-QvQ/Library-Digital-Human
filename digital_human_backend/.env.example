# ============================================
# 鏁板瓧浜哄悗绔郴缁熺幆澧冨彉閲忛厤缃ā鏉?# Digital Human Backend Environment Variables
# ============================================
# 
# 浣跨敤鏂规硶锛?# 1. 澶嶅埗姝ゆ枃浠朵负 .env: cp .env.example .env
# 2. 鏍规嵁瀹為檯鎯呭喌淇敼閰嶇疆鍊?# 3. 涓嶈灏?.env 鏂囦欢鎻愪氦鍒扮増鏈帶鍒剁郴缁?#

# ============================================
# 鏈嶅姟閰嶇疆
# ============================================
HOST=0.0.0.0
PORT=8000
DEBUG=False

# ============================================
# 鏁版嵁搴撻厤缃紙鍙€夛紝鏍规嵁瀹為檯闇€姹傚惎鐢級
# ============================================
DATABASE_URL=postgresql://user:password@localhost/digital_human
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://localhost:27017

# ============================================
# Neo4j鍥炬暟鎹簱閰嶇疆
# ============================================
# If using project Docker (data/Neo4j): port 7687, password mem0test123
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jneo4j

# ============================================
# ChromaDB鍚戦噺鏁版嵁搴撻厤缃?# ============================================
CHROMADB_PERSIST_DIR=./data/chromadb

# ============================================
# AI妯″瀷閰嶇疆
# ============================================
OPENAI_API_KEY=
HUGGINGFACE_TOKEN=
OLLAMA_BASE_URL=http://localhost:11434
# 默认对话模型（必须是你本机 `GET /api/tags` 能看到的 name）
# 示例：gemma3:1b / qwen3:latest / EntropyYue/chatglm3:latest
OLLAMA_DEFAULT_MODEL=gemma3:1b

# Unity 下拉框会传 model_key=Chatglm 或 Qwen，这里配置它们映射到的真实 Ollama 模型名
OLLAMA_MODEL_CHATGLM=EntropyYue/chatglm3:latest
OLLAMA_MODEL_QWEN=qwen3:latest

# ============================================
# 妯″瀷鍜屾暟鎹矾寰勯厤缃?# ============================================
MODELS_DIR=./models
DATA_DIR=./data

# ============================================
# CORS璺ㄥ煙閰嶇疆
# ============================================
CORS_ORIGINS=*

# ============================================
# 鏃ュ織閰嶇疆
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
